# Sequoia CLI - AT Protocol credentials for publishing to PDS
# Copy this file to .env and fill in your values

# Your AT Protocol handle (e.g., fairfruit.tv)
ATP_IDENTIFIER=fairfruit.tv

# App password from your PDS (Settings > App Passwords)
ATP_APP_PASSWORD=

# Your PDS URL
PDS_URL=https://pds.yfrit.social
