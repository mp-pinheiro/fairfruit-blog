---
import Base from './Base.astro';

interface Props {
	title: string;
	description: string;
	publishDate: Date;
	tags?: string[];
	bskyPostUri?: string;
}

const { title, description, publishDate, tags = [], bskyPostUri } = Astro.props;

const formattedDate = publishDate.toLocaleDateString('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<Base title={`${title} - Fairfruit's Blog`} description={description}>
	<article>
		<a href="/" class="back-link">&larr; Back to posts</a>
		<header class="post-header">
			<h1>{title}</h1>
			<div class="post-meta">
				<time datetime={publishDate.toISOString()}>{formattedDate}</time>
				{tags.length > 0 && (
					<div class="tags">
						{tags.map((tag) => (
							<span class="tag">{tag}</span>
						))}
					</div>
				)}
			</div>
		</header>
		<div class="post-content">
			<slot />
		</div>
	</article>
</Base>

<style>
	.post-header {
		margin-bottom: 2rem;
		background: var(--color-tertiary);
		border: 1px solid var(--color-secondary);
		border-radius: 10px;
		padding: 1.25rem 1.5rem;
	}

	.back-link {
		display: inline-block;
		margin-bottom: 1rem;
		font-size: 0.9rem;
	}

	h1 {
		font-size: 2rem;
		margin-bottom: 0.5rem;
	}

	.post-meta {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
		font-size: 0.9rem;
		opacity: 0.8;
	}

	.tags {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.tag {
		background: var(--color-secondary);
		padding: 2px 10px;
		border-radius: 12px;
		font-size: 0.8rem;
	}

	.post-content {
		font-size: 1.05rem;
	}

	.post-content :global(h2) {
		margin-top: 2rem;
		margin-bottom: 0.75rem;
	}

	.post-content :global(h3) {
		margin-top: 1.5rem;
		margin-bottom: 0.5rem;
	}

	.post-content :global(h4) {
		margin-top: 1.25rem;
		margin-bottom: 0.5rem;
	}

	.post-content :global(p) {
		margin-bottom: 1rem;
	}

	.post-content :global(ul),
	.post-content :global(ol) {
		margin-bottom: 1rem;
		padding-left: 2rem;
	}

	.post-content :global(li) {
		margin-bottom: 0.5rem;
	}

	.post-content :global(strong) {
		color: var(--color-primary);
	}

	.post-content :global(img) {
		margin: 1.5rem 0;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
	}

	@media (max-width: 600px) {
		.back-link {
			margin-bottom: 0.5rem;
		}

		.post-header {
			padding: 0.75rem 1rem;
			margin-bottom: 1.25rem;
		}

		h1 {
			font-size: 1.3rem;
		}

		.post-content {
			font-size: 1rem;
		}
	}
</style>
